<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project.CheckInPage"
             BackgroundColor="#F3F6FB"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid HeightRequest="185"
                  Padding="26,28,26,24">

                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0.0"/>
                        <GradientStop Color="#2563EB" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout Spacing="8"
                                     VerticalOptions="Center">

                    <Label Text="GPS Check-in"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Verify your classroom location before attendance."
                           FontSize="15"
                           TextColor="#EAF2FF"/>

                    <!-- ⭐ 动态状态提示 -->
                    <Frame CornerRadius="18"
                           Padding="12,8"
                           HasShadow="False"
                           HorizontalOptions="Start">

                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding StatusColor}"
                                         Value="Green">
                                <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                            </DataTrigger>

                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding StatusColor}"
                                         Value="Red">
                                <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                            </DataTrigger>
                        </Frame.Triggers>

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="●"
                                   TextColor="{Binding StatusColor}"
                                   FontSize="14"
                                   VerticalOptions="Center"/>

                            <Label Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#1E3A5F"/>
                        </HorizontalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Grid>

            <!-- Content -->
            <VerticalStackLayout Padding="24,24,24,42"
                                 Spacing="18"
                                 Margin="0,-42,0,0">

                <!-- Class Card -->
                <Frame BackgroundColor="#FCFDFF"
                       CornerRadius="28"
                       Padding="22"
                       HasShadow="True">

                    <Grid ColumnDefinitions="*,Auto">

                        <VerticalStackLayout Spacing="5">

                            <Label Text="Current Class"
                                   FontSize="15"
                                   TextColor="Gray"/>

                            <Label Text="Mobile Application Development"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#1E3A5F"/>

                            <Label Text="classroom 308 • Information Building"
                                   FontSize="14"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>

                        <Frame Grid.Column="1"
                               BackgroundColor="#EAF2FF"
                               CornerRadius="18"
                               WidthRequest="58"
                               HeightRequest="58"
                               Padding="0"
                               HasShadow="False">

                            <Label Text="📚"
                                   FontSize="30"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                    </Grid>
                </Frame>

                <!-- GPS Card -->
                <Frame BackgroundColor="White"
                       CornerRadius="28"
                       Padding="20"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="18">

                        <!-- Fake Map -->
                        <Border BackgroundColor="#EAF2FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 24"
                                HeightRequest="190">

                            <Grid>

                                <Ellipse WidthRequest="120"
                                         HeightRequest="120"
                                         Fill="#DCEBFF"
                                         Opacity="0.9"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"/>

                                <Ellipse WidthRequest="70"
                                         HeightRequest="70"
                                         Fill="#BFDBFE"
                                         Opacity="0.9"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"/>

                                <Frame BackgroundColor="#2563EB"
                                       CornerRadius="24"
                                       WidthRequest="58"
                                       HeightRequest="58"
                                       Padding="0"
                                       HasShadow="True"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">

                                    <Label Text="📍"
                                           FontSize="30"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>

                                <!-- ⭐ 实时地址 -->
                                <Frame BackgroundColor="White"
                                       CornerRadius="14"
                                       Padding="10,6"
                                       HasShadow="True"
                                       HorizontalOptions="Center"
                                       VerticalOptions="End"
                                       Margin="0,0,0,16">

                                    <Label Text="{Binding Location}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1E3A5F"/>
                                </Frame>

                            </Grid>
                        </Border>

                        <!-- ⭐ 状态区域（完全动态） -->
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <!-- 图标 -->
                            <Frame WidthRequest="50"
                                   HeightRequest="50"
                                   CornerRadius="16"
                                   Padding="0"
                                   HasShadow="False">

                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding StatusColor}"
                                                 Value="Green">
                                        <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                    </DataTrigger>

                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding StatusColor}"
                                                 Value="Red">
                                        <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                    </DataTrigger>
                                </Frame.Triggers>

                                <Label Text="✓"
                                       FontSize="24"
                                       TextColor="{Binding StatusColor}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>

                            <!-- 文本 -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">

                                <Label Text="{Binding StatusText}"
                                       TextColor="{Binding StatusColor}"
                                       FontAttributes="Bold"
                                       FontSize="16"/>

                                <Label Text="{Binding Location}"
                                       FontSize="13"
                                       TextColor="Gray"/>

                                <Label Text="{Binding DistanceText}"
                                       FontSize="13"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Button -->
                <Button Text="📍 Confirm Check In"
                        Clicked="OnConfirmCheckInClicked"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="58"
                        CornerRadius="18"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>