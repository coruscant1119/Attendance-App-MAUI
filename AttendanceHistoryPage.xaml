<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project.AttendanceHistoryPage"
             BackgroundColor="#F3F6FB"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero Header -->
            <Grid HeightRequest="185"
                  Padding="26,28,26,24">

                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0.0"/>
                        <GradientStop Color="#2563EB" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout Spacing="8"
                                     VerticalOptions="Center">

                    <Label Text="Attendance History"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Review your recent check-in records."
                           FontSize="15"
                           TextColor="#EAF2FF"/>

                    <Frame BackgroundColor="#EAF2FF"
                           CornerRadius="18"
                           Padding="12,8"
                           HasShadow="False"
                           HorizontalOptions="Start">

                        <Label Text="4 Recent Records"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1E3A5F"/>
                    </Frame>

                </VerticalStackLayout>
            </Grid>

            <!-- Content -->
            <VerticalStackLayout Padding="24,24,24,42"
                                 Spacing="18"
                                 Margin="0,-42,0,0">

                <!-- Summary Card -->
                <Frame BackgroundColor="White"
                       CornerRadius="28"
                       Padding="22"
                       HasShadow="True">

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="12">

                        <!-- Present -->
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="4">

                            <Label Text="Present"
                                   FontSize="13"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"/>

                            <Label Text="2"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#16A34A"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Late -->
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4">

                            <Label Text="Late"
                                   FontSize="13"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"/>

                            <Label Text="1"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#F97316"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Absent -->
                        <VerticalStackLayout Grid.Column="2"
                                             Spacing="4">

                            <Label Text="Absent"
                                   FontSize="13"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"/>

                            <Label Text="1"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- Section Title -->
                <Label Text="Recent Records"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1E3A5F"/>

                <!-- Record 1 -->
                <Frame BackgroundColor="White"
                       CornerRadius="24"
                       Padding="18"
                       HasShadow="True">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <Frame BackgroundColor="#DCFCE7"
                               CornerRadius="16"
                               WidthRequest="52"
                               HeightRequest="52"
                               Padding="0"
                               HasShadow="False">

                            <Label Text="✓"
                                   FontSize="24"
                                   TextColor="#16A34A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="5">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label Text="Mobile Application Development"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#1E3A5F"/>

                                <Frame Grid.Column="1"
                                       BackgroundColor="#DCFCE7"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False">

                                    <Label Text="Present"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#16A34A"/>
                                </Frame>
                            </Grid>

                            <Label Text="27 Apr 2026 • 08:10"
                                   FontSize="14"
                                   TextColor="Gray"/>

                            <Label Text="Location: Campus Information Building"
                                   FontSize="14"
                                   TextColor="#2563EB"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- Record 2 -->
                <Frame BackgroundColor="White"
                       CornerRadius="24"
                       Padding="18"
                       HasShadow="True">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <Frame BackgroundColor="#DCFCE7"
                               CornerRadius="16"
                               WidthRequest="52"
                               HeightRequest="52"
                               Padding="0"
                               HasShadow="False">

                            <Label Text="✓"
                                   FontSize="24"
                                   TextColor="#16A34A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="5">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label Text="Data Science Fundamentals"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#1E3A5F"/>

                                <Frame Grid.Column="1"
                                       BackgroundColor="#DCFCE7"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False">

                                    <Label Text="Present"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#16A34A"/>
                                </Frame>
                            </Grid>

                            <Label Text="26 Apr 2026 • 10:30"
                                   FontSize="14"
                                   TextColor="Gray"/>

                            <Label Text="Location: Campus Rixin Building"
                                   FontSize="14"
                                   TextColor="#2563EB"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- Record 3 -->
                <Frame BackgroundColor="White"
                       CornerRadius="24"
                       Padding="18"
                       HasShadow="True">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <Frame BackgroundColor="#FFEDD5"
                               CornerRadius="16"
                               WidthRequest="52"
                               HeightRequest="52"
                               Padding="0"
                               HasShadow="False">

                            <Label Text="!"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#F97316"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="5">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label Text="Programming I"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#1E3A5F"/>

                                <Frame Grid.Column="1"
                                       BackgroundColor="#FFEDD5"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False">

                                    <Label Text="Late"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#F97316"/>
                                </Frame>
                            </Grid>

                            <Label Text="25 Apr 2026 • 09:15"
                                   FontSize="14"
                                   TextColor="Gray"/>

                            <Label Text="Location: Campus Information Building"
                                   FontSize="14"
                                   TextColor="#2563EB"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- Record 4 -->
                <Frame BackgroundColor="White"
                       CornerRadius="24"
                       Padding="18"
                       HasShadow="True">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <Frame BackgroundColor="#DBEAFE"
                               CornerRadius="16"
                               WidthRequest="52"
                               HeightRequest="52"
                               Padding="0"
                               HasShadow="False">

                            <Label Text="✕"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="5">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label Text="Data Structures"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#1E3A5F"/>

                                <Frame Grid.Column="1"
                                       BackgroundColor="#DBEAFE"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False">

                                    <Label Text="Absent"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2563EB"/>
                                </Frame>
                            </Grid>

                            <Label Text="24 Apr 2026 • 08:30"
                                   FontSize="14"
                                   TextColor="Gray"/>

                            <Label Text="Location: Teaching Building No. 1 in the North Campus"
                                   FontSize="14"
                                   TextColor="#2563EB"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>