<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project.AttendanceHistoryPage"
             BackgroundColor="#F3F6FB"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid HeightRequest="185" Padding="26,28,26,24">

                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0.0"/>
                        <GradientStop Color="#2563EB" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout Spacing="8" VerticalOptions="Center">

                    <Label Text="Attendance History"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Review your recent check-in records."
                           FontSize="15"
                           TextColor="#EAF2FF"/>

                </VerticalStackLayout>
            </Grid>

            <!-- 内容 -->
            <VerticalStackLayout Padding="24,24,24,42"
                                 Spacing="18"
                                 Margin="0,-42,0,0">

                <!-- 标题 -->
                <Label Text="Recent Records"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1E3A5F"/>

                <!-- ⭐ 核心：Data Binding 列表 -->
                <CollectionView ItemsSource="{Binding Records}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Frame BackgroundColor="White"
                                   CornerRadius="24"
                                   Padding="18"
                                   HasShadow="True"
                                   Margin="0,0,0,12">

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="14">

                                    <!-- 左图标 -->
                                    <Frame BackgroundColor="#EAF2FF"
                                           CornerRadius="16"
                                           WidthRequest="52"
                                           HeightRequest="52"
                                           Padding="0"
                                           HasShadow="False">

                                        <Label Text="●"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>

                                    <!-- 内容 -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="5">

                                        <Grid ColumnDefinitions="*,Auto">
                                            
                                            <Label Text="{Binding CourseName}"
                                                
                                                    FontSize="17"
                                                    FontAttributes="Bold"
                                                    TextColor="#1E3A5F"/>
                                            <!-- 用户 -->
                                            <Label Text="{Binding Username}"
                                                   FontSize="13"
                                                   
                                                   TextColor="Gray"/>

                                            <!-- 状态 -->
                                            <Frame Grid.Column="1"
                                                   BackgroundColor="#EAF2FF"
                                                   CornerRadius="14"
                                                   Padding="10,5"
                                                   HasShadow="False">

                                                <Label Text="{Binding Status}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="#2563EB"/>
                                            </Frame>
                                        </Grid>

                                        <!-- 时间 -->
                                        <Label Text="{Binding Time}"
                                               FontSize="14"
                                               TextColor="Gray"/>

                                        <!-- 位置 -->
                                        <Label Text="Location: Campus"
                                               FontSize="14"
                                               TextColor="#2563EB"/>

                                    </VerticalStackLayout>

                                </Grid>

                            </Frame>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>